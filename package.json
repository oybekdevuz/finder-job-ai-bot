{
  "name": "finder-job-ai",
  "scripts": {
    "start": "npm run build:win && dotenv -e .env -- node ./apps/host-main/build/index.mjs",
    "start:dev": "dotenv -e .env -- node ./apps/host-main/build/index.mjs",
    "start:pdf": "npx --yes tsx tools/pdf-parser/index.ts",
    "start:x": "npm run build:x && dotenv -e .env -- node ./apps/host-main/build/index.mjs",
    "start:win": "npm run pm2:stop && npm run build:win && npm run pm2:start",
    "pm2:start": "pm2 start ./config/ecosystem.config.js",
    "pm2:stop": "pm2 kill",
    "test": "npm run start && dotenv -e .env -- node ./packages/host-test/build/index.mjs",
    "build:win": ".\\scripts\\win\\build.bat",
    "build:x": "sh ./scripts/linux/build.sh",
    "postinstall": "npm run postinstall:pm2",
    "postinstall:pm2": "npm list -g pm2 || npm install -g pm2"
  },
  "workspaces": [
    "./modules/*",
    "./apps/*"
  ],
  "devDependencies": {
    "@enalmada/bun-externals": "^0.0.8",
    "@rollup/plugin-typescript": "11.1.6",
    "@types/bun": "1.2.2",
    "@types/lodash-es": "4.17.12",
    "@types/node": "22.10.3",
    "@types/uuid": "10.0.0",
    "@types/xml2js": "0.4.14",
    "dotenv-cli": "7.4.2",
    "glob": "11.0.1",
    "kill-port": "2.0.1",
    "rimraf": "6.0.1",
    "rollup": "3.29.4",
    "rollup-plugin-dts": "6.1.1",
    "rollup-plugin-inject-process-env": "1.3.1",
    "rollup-plugin-peer-deps-external": "2.2.4",
    "tape": "^5.9.0",
    "touch-cli": "0.0.1",
    "tslib": "2.7.0",
    "worker-testbed": "^1.0.10"
  },
  "dependencies": {
    "@hono/node-server": "1.13.7",
    "@hono/node-ws": "1.0.4",
    "@langchain/cohere": "0.3.2",
    "@langchain/core": "^0.3.62",
    "@langchain/google-genai": "^0.2.18",
    "@langchain/ollama": "0.2.0",
    "@langchain/openai": "0.4.8",
    "@langchain/xai": "^0.0.3",
    "@modelcontextprotocol/sdk": "^1.10.2",
    "@tensorflow/tfjs-backend-wasm": "4.22.0",
