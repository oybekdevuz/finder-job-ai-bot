    "chromadb-default-embed": "2.13.2",
    "cohere-ai": "7.16.0",
    "di-factory": "1.0.9",
    "di-kit": "1.0.14",
    "di-scoped": "1.0.16",
    "di-singleton": "1.0.5",
    "dotenv": "^16.5.0",
    "form-data": "^4.0.2",
    "functools-kit": "1.0.80",
    "get-moment-stamp": "1.1.1",
    "gpt4all": "4.0.0",
    "grammy": "^1.38.4",
    "hono": "4.6.13",
