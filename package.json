{
  "name": "finder-job-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "npm run build:win && dotenv -e .env -- node ./apps/host-main/build/index.mjs",
    "start:dev": "dotenv -e .env -- node ./apps/host-main/build/index.mjs",
    "start:x": "npm run build:x && dotenv -e .env -- node ./apps/host-main/build/index.mjs",
    "deploy": "node --env-file=.env ./apps/host-main/build/index.mjs",
    "start:win": "npm run pm2:stop && npm run build:win && npm run pm2:start",
    "pm2:start": "pm2 start ./config/ecosystem.config.js",
    "pm2:stop": "pm2 kill",
    "build:win": ".\\scripts\\win\\build.bat",
    "build:x": "sh ./scripts/linux/build.sh",
    "postinstall": "npm run postinstall:pm2",
    "postinstall:pm2": "npm list -g pm2 || npm install -g pm2"
  },
  "workspaces": [
    "./modules/*",
    "./apps/*"
  ],
  "devDependencies": {
    "@rollup/plugin-typescript": "11.1.6",
    "@types/node": "22.10.3",
    "dotenv-cli": "7.4.2",
    "rollup": "3.29.4",
    "rollup-plugin-dts": "6.1.1",
    "rollup-plugin-inject-process-env": "1.3.1",
    "rollup-plugin-peer-deps-external": "2.2.4"
  },
  "dependencies": {
    "@hono/node-server": "1.13.7",
    "@hono/node-ws": "1.0.4",
    "@langchain/core": "^0.3.62",
    "@langchain/ollama": "0.2.0",
    "@langchain/openai": "0.4.8",
    "agent-swarm-kit": "1.1.158",
    "dotenv": "^16.5.0",
    "functools-kit": "1.0.80",
    "hono": "4.6.13",
    "ioredis": "5.4.2",
    "openai": "4.82.0",
    "pinolog": "1.0.4",
    "telegram": "^2.26.22",
    "zod": "3.24.1"
  }
}
